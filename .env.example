# --- Aggregate counters (anonymous; no PII is ever stored) ---
# Create a free Upstash Redis DB at https://upstash.com and paste the REST creds.
# Without these, the app falls back to in-memory counters that reset between
# serverless invocations (fine for local dev, NOT for production analytics).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Event-level analytics (anonymous; no PII) ---
# Neon Postgres pooled connection string (the host with "-pooler"). Stores quiz
# selections, results, and app-CTA clicks tied to a random session id. Without
# it, event logging silently no-ops (app works exactly the same). See the
# quiz_events table SQL in the setup notes.
DATABASE_URL=

# --- Public URL of THIS quiz site (used for share links / OG absolute URLs) ---
# Set this in Vercel to your real domain once deployed.
NEXT_PUBLIC_SITE_URL=https://waveparticle-quiz.vercel.app

# --- Optional: protect the /api/stats dashboard endpoint ---
# If set, /api/stats requires ?token=<value> or an x-stats-token header.
# Leave empty in local dev to browse stats freely.
STATS_TOKEN=
